# THE PHILOSOPHY MACHINE — environment variables
# The MVP runs with NONE of these set (anonymous, client-side, mock AI).
# Add them to enable the corresponding backend feature.

# ── AI philosopher chat (docs/00 §AI) ──
# Configure ANY ONE provider below. First one set wins. If none, /chat returns
# an in-character mock reply so the feature always works.

# FREE — Google Gemini. Get a key (no credit card): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# FREE — Groq (fast, open models). Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# FREE — local Ollama (no key, runs on your machine): https://ollama.com
# Install, run `ollama pull llama3.2`, then set the base URL below.
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# PAID — Anthropic Claude (highest quality). https://console.anthropic.com
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-opus-4-8

# ── Database / persistence (Phase 3, docs/04 & docs/07) ──
# Enables saving results, cross-device history, real rarity distributions.
DATABASE_URL=postgresql://user:password@localhost:5432/philosophy_machine

# ── Auth — Google OAuth via NextAuth (Phase 3) ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Analytics — PostHog (docs/01 §9) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Payments — Stripe (Phase 4) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Public base URL (used for share links / OG absolute URLs in production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
